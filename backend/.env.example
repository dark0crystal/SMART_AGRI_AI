# Copy to `.env` and fill in. See README "Firebase" for details.
# `backend/.env` is gitignored.

# Django
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=true
# DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Firebase Admin — set exactly ONE of the following (same JSON, different formats):
# Path to the service account JSON from Firebase Console → Project settings → Service accounts
# (Relative paths are resolved from the backend folder next to manage.py.)
FIREBASE_CREDENTIALS_PATH=firebase-adminsdk-yourproject.json

# Or paste the raw JSON on one line / use BASE64 instead of PATH:
# FIREBASE_CREDENTIALS_JSON=
# FIREBASE_CREDENTIALS_BASE64=

# Optional overrides (usually inferred from the service account file):
# FIREBASE_PROJECT_ID=
# FIREBASE_STORAGE_BUCKET=
# FIREBASE_DATABASE_URL=

# Optional: comma-separated HTTPS prefixes; if set, diagnosis image URLs must match one.
# ALLOWED_STORAGE_IMAGE_URL_PREFIXES=https://firebasestorage.googleapis.com/

# Production CORS when DJANGO_DEBUG=false:
# CORS_ALLOWED_ORIGINS=https://your-frontend.example
